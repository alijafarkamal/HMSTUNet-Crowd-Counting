# Copy to secrets.toml locally (never commit real secrets).
# On Streamlit Community Cloud: App → ⋮ → Settings → Secrets.
#
# Use a direct download URL to best.pth (Hugging Face "resolve" link, raw file URL, etc.).

CHECKPOINT_URL = "https://huggingface.co/YOUR_USER/YOUR_REPO/resolve/main/best.pth"
